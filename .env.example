# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: sqlite (default) or mysql
DB_ENGINE=sqlite

# MySQL (only when DB_ENGINE=mysql)
# DB_NAME=baymax_db
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306

# Google Gemini (emergency chat)
GEMINI_API_KEY=your-api-key-here

# Gmail SMTP (contact form) — use App Password, not main password
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your16charapppassword
# Optional — inbox for contact form (defaults to EMAIL_HOST_USER)
# CONTACT_RECIPIENT_EMAIL=your@gmail.com

# Google OAuth (login with Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
